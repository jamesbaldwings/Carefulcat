{
    "name": "careful-cat-rescue/website",
    "description": "Careful Cat Rescue Website - PHP Version",
    "type": "project",
    "require": {
        "php": ">=8.0",
        "stripe/stripe-php": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "includes/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

