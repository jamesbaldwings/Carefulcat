# Database Configuration
DB_HOST=localhost
DB_NAME=cat_rescue
DB_USER=your_database_username
DB_PASS=your_database_password
DB_PORT=3306

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Site Configuration
SITE_URL=https://yourdomain.com
SITE_NAME=Careful Cat Rescue
SITE_EMAIL=info@carefulcatrescue.org

# Admin Configuration
ADMIN_EMAIL=admin@carefulcatrescue.org
ADMIN_PASSWORD=change_this_password_immediately

# Session Configuration
SESSION_LIFETIME=7200
SESSION_SECURE=true

# Email Configuration (optional - for contact form notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
SMTP_FROM=noreply@carefulcatrescue.org

# Upload Configuration
MAX_UPLOAD_SIZE=10485760
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
ALLOWED_VIDEO_TYPES=mp4,webm,mov

# Environment
ENVIRONMENT=production
DEBUG_MODE=false

